#!/usr/bin/env python3
"""bin/task — task management CLI.

Subcommands:
  new <type>             Create a new task interactively.
  move <id> <status>     Flip a task's status field.
  list                   List tasks (kanban-by-frontmatter).

Per docs/11-task-format.md.
Layout is read from .agents/manifest.yaml (tasks-layout field).
"""

from __future__ import annotations

import argparse
import os
import re
import sys
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

import yaml

# Add bin/ to sys.path
sys.path.insert(0, str(Path(__file__).resolve().parent))

from lib.manifest import find_repo_root, load_manifest
from lib.task_schema import (
    VALID_STATUSES,
    VALID_TYPES,
    folder_for_status,
    layout_folders,
    load_all_tasks,
    parse_frontmatter,
    validate_dependencies,
    validate_frontmatter,
    validate_transition,
)
from lib.transitions import apply_transition


# ---------------------------------------------------------------------------
# Context: thin carrier so cmd_* functions share manifest-derived state
# without using globals.
# ---------------------------------------------------------------------------

@dataclass
class Context:
    repo_root: Path
    layout: str


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def slugify(text: str) -> str:
    """Convert a title to a kebab-case slug."""
    slug = re.sub(r"[^a-z0-9]+", "-", text.lower())
    return slug.strip("-")[:50]


def next_task_id(tasks_dir: Path, layout: str) -> int:
    """Find the next available numeric ID by scanning all configured folders."""
    existing_ids: set[int] = set()
    for folder in layout_folders(layout):
        folder_path = tasks_dir / folder
        if not folder_path.exists():
            continue
        for task_file in folder_path.glob("*.md"):
            match = re.match(r"^(\d+)", task_file.stem)
            if match:
                existing_ids.add(int(match.group(1)))
    return max(existing_ids, default=0) + 1


def _emit_frontmatter(data: dict[str, Any]) -> str:
    """Serialise a frontmatter dict back to YAML fenced text.

    Uses yaml.safe_dump so both 'status:' and 'updated:' are written
    atomically in a single pass (avoids the two-regex fragility of the
    original cmd_move).
    """
    return "---\n" + yaml.safe_dump(data, default_flow_style=False, sort_keys=False) + "---"


def _now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

def cmd_new(ctx: Context, args: argparse.Namespace) -> int:
    tasks_dir = ctx.repo_root / "tasks"
    tasks_dir.mkdir(exist_ok=True)

    # Ensure all configured folders exist.
    for folder in layout_folders(ctx.layout):
        (tasks_dir / folder).mkdir(exist_ok=True)

    # Determine target status from --status flag (default "open").
    status = args.status

    # Interactive prompts (with defaults)
    if args.skip_prompts:
        title = args.title or "Untitled"
        scope = args.scope or "general"
        user_story = args.user_story or "TBD"
        ac_lines: list[str] = args.ac or []
        fan_out = args.fan_out or 1
        needs_architect = args.needs_architect if args.needs_architect is not None else True
        trivial = args.trivial or False
        depends_on: list[int] = args.depends_on or []
        parent = args.parent
        slug = args.slug or slugify(title)
    else:
        title = input("Title: ").strip() or "Untitled"
        scope = input("Scope: ").strip() or "general"
        print("User story (As a / I want / so that):")
        user_story = input("> ").strip() or "TBD"
        print("Acceptance criteria (one per line, blank to finish):")
        ac_lines = []
        while True:
            line = input("> ").strip()
            if not line:
                break
            ac_lines.append(line)
        fan_out_str = input("fan-out [1]: ").strip() or "1"
        fan_out = int(fan_out_str)
        needs_architect_str = input("needs-architect [yes]: ").strip().lower() or "yes"
        needs_architect = needs_architect_str in ("y", "yes", "true", "1")
        trivial_str = input("trivial [no]: ").strip().lower() or "no"
        trivial = trivial_str in ("y", "yes", "true", "1")
        depends_on_str = input("depends-on (comma-separated IDs): ").strip()
        depends_on = [int(x.strip()) for x in depends_on_str.split(",") if x.strip()] if depends_on_str else []
        parent = None
        slug = slugify(title)

    task_id = parent if parent else next_task_id(tasks_dir, ctx.layout)
    if parent:
        # Sub-task: append a letter
        parent_subtasks = list(tasks_dir.rglob(f"{parent}*.md"))
        letter = chr(ord("a") + len([t for t in parent_subtasks if re.match(rf"^{parent}[a-z]", t.stem)]))
        task_filename = f"{parent}{letter}-{slug}.md"
        task_id_str = f"{parent}{letter}"
    else:
        task_filename = f"{task_id:03d}-{slug}.md"
        task_id_str = f"{task_id:03d}"

    now = _now_iso()

    # Build frontmatter as a dict so we can validate before writing.
    fm_data: dict[str, Any] = {
        "id": task_id_str,
        "title": title,
        "type": args.type,
        "scope": scope,
        "status": status,
        "fan-out": fan_out,
        "needs-architect": needs_architect,
        "plan-approved": False,
        "result-approved": False,
        "trivial": trivial,
        "depends-on": depends_on,
        "created": now,
        "updated": now,
    }
    if parent:
        fm_data["parent"] = parent

    # Validate frontmatter.
    fm_errors = validate_frontmatter(fm_data, ctx.layout)
    if fm_errors:
        for err in fm_errors:
            print(f"Error: {err}", file=sys.stderr)
        return 1

    # Validate dependencies.
    all_tasks = load_all_tasks(ctx.repo_root, ctx.layout)
    dep_strs = [str(d) for d in depends_on]
    dep_errors = validate_dependencies(task_id_str, dep_strs, all_tasks)
    if dep_errors:
        for err in dep_errors:
            print(f"Error: {err}", file=sys.stderr)
        return 1

    # Route to the correct folder.
    target_folder = folder_for_status(status, ctx.layout)
    task_file = tasks_dir / target_folder / task_filename

    body = f"""

# Task {task_id_str}: {title}

## Objective
{user_story}

## User story
{user_story}

## Acceptance criteria
"""
    for i, ac in enumerate(ac_lines, 1):
        body += f"- AC{i}: {ac}\n"
    body += """
## Plan

<!-- Filled in by the Planner -->

## Verdict

<!-- Filled in by the Librarian sweep at archival -->
"""

    task_file.write_text(_emit_frontmatter(fm_data) + body)
    print(f"\nCreated {task_file.relative_to(ctx.repo_root)}\n")
    return 0


def cmd_move(ctx: Context, args: argparse.Namespace) -> int:
    """Move a task to a new status.

    Delegates all validation, frontmatter mutation, and file-move logic
    to transitions.apply_transition — the single shared code path for
    both manual and automatic flips (AC5).
    """
    try:
        new_path = apply_transition(
            repo_root=ctx.repo_root,
            task_id=args.id,
            new_status=args.status,
            layout=ctx.layout,
        )
    except ValueError as exc:
        print(f"Error: {exc}", file=sys.stderr)
        return 1

    print(new_path)
    return 0


def cmd_list(ctx: Context, args: argparse.Namespace) -> int:
    tasks_dir = ctx.repo_root / "tasks"
    folders = layout_folders(ctx.layout)

    # Verify at least one folder exists.
    if not any((tasks_dir / f).exists() for f in folders):
        print(f"No task folders found under {tasks_dir}.")
        return 0

    by_status: dict[str, list[str]] = {}
    folder_order: list[str] = []  # tracks which folders had files

    for folder in folders:
        folder_path = tasks_dir / folder
        if not folder_path.exists():
            continue
        folder_had_tasks = False
        for task_file in sorted(folder_path.glob("*.md")):
            content = task_file.read_text()
            status_match = re.search(r"^status:\s*(\S+)", content, re.MULTILINE)
            title_match = re.search(r"^title:\s*(.+)", content, re.MULTILINE)
            status = status_match.group(1) if status_match else "unknown"
            title = title_match.group(1).strip() if title_match else task_file.stem
            by_status.setdefault(status, []).append(f"{task_file.stem} — {title}")
            folder_had_tasks = True
        if folder_had_tasks:
            folder_order.append(folder)

    print()

    if ctx.layout == "legacy-four-folder":
        # Show per-folder section headers for the human view.
        for folder in folders:
            folder_path = tasks_dir / folder
            if not folder_path.exists():
                continue
            # Collect tasks that land in this folder per the mapping.
            statuses_in_folder = [
                s for s in VALID_STATUSES
                if folder_for_status(s, ctx.layout) == folder
            ]
            folder_tasks: list[str] = []
            for status in statuses_in_folder:
                folder_tasks.extend(by_status.get(status, []))
            if folder_tasks:
                print(f"### {folder} ({len(folder_tasks)})")
                for line in folder_tasks:
                    print(f"  - {line}")
                print()
    else:
        # Standard layout: group by status in logical order.
        for status in VALID_STATUSES:
            if status in by_status:
                print(f"## {status} ({len(by_status[status])})")
                for line in by_status[status]:
                    print(f"  - {line}")
                print()

    return 0


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main() -> int:
    parser = argparse.ArgumentParser(description="budai task management.")
    parser.add_argument("--version", action="version", version="budai task 0.1.0")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_new = sub.add_parser("new", help="Create a new task.")
    p_new.add_argument("type", choices=VALID_TYPES)
    p_new.add_argument("--skip-prompts", action="store_true")
    p_new.add_argument("--title")
    p_new.add_argument("--scope")
    p_new.add_argument("--user-story")
    p_new.add_argument("--ac", action="append", default=[])
    p_new.add_argument("--fan-out", type=int)
    p_new.add_argument("--needs-architect", type=lambda v: v.lower() in ("yes", "true", "1"))
    p_new.add_argument("--trivial", action="store_true")
    p_new.add_argument("--depends-on", type=int, action="append", default=[])
    p_new.add_argument("--parent", type=int)
    p_new.add_argument("--slug")
    p_new.add_argument(
        "--status",
        choices=VALID_STATUSES,
        default="open",
        help="Initial status for the new task (default: open).",
    )

    p_move = sub.add_parser("move", help="Move a task to a different status.")
    p_move.add_argument("id")
    p_move.add_argument("status")

    sub.add_parser("list", help="List tasks.")

    args = parser.parse_args()
    repo_root = find_repo_root()
    manifest = load_manifest(repo_root)
    ctx = Context(repo_root=repo_root, layout=manifest.tasks_layout)

    cmds = {"new": cmd_new, "move": cmd_move, "list": cmd_list}
    return cmds[args.cmd](ctx, args)


if __name__ == "__main__":
    sys.exit(main())
